# ── Oxmaint Predictive Agent — Backend API Environment Template ──────
# Backend .env for API container only. Copy to .env and fill in real values.
# Separate from frontend/.env which has only API_BASE_URL.

# ── Supabase / PostgreSQL ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_KEY=your-supabase-key
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key
GROQ_API_KEY=your-groq-api-key
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# ── Model Paths / HuggingFace ────────────────────────────────────────
BGE_M3_MODEL_ID=BAAI/bge-m3
LIGHTGBM_MODEL_PATH=app/models/sensor_lgbm_model.txt
LIGHTGBM_FEATURE_COLUMNS_PATH=app/models/sensor_feature_columns.json
HF_TOKEN=your-huggingface-token

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Streamlit ────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
# Docker Compose frontend service overrides this to http://api:8000.
# Use localhost only when running frontend directly on host (outside Docker).
API_BASE_URL=http://localhost:8000